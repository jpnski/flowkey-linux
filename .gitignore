# ──────────────────────────────────────────────────────────────
# Flowkey — Linux source repo ignore rules
# ──────────────────────────────────────────────────────────────

# Private runtime data
data/

# Live working config
config/grammar_hotkey.config.json

# Machine-specific logs
logs/
*.log
*.log.*

# Build / packaging output
build/
dist/
out/
scripts/.venv/
*.egg-info/

# Caches
.ruff_cache/
.pytest_cache/
__pycache__/
*.py[cod]

# Local agent / editor state
.claude/
.cursor/
AGENTS.md
*.local.json
.vscode/
.idea/

# Process/runtime artifacts
*.pid

# Python virtual environments
.venv/
venv/

# OS junk
.DS_Store
Thumbs.db
